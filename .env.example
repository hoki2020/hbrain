# JWT
JWT_SECRET=change-me-to-a-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# Kuzu
KUZU_DB_PATH=./data/kuzu/hbrain.kuzu

# LLM Provider: "openai" or "anthropic"
LLM_PROVIDER=openai

# OpenAI-compatible API (also works with local servers like Ollama)
OPENAI_BASE_URL=http://127.0.0.1:8317/v1
OPENAI_API_KEY=your_api_key_here
OPENAI_MODEL=mimo-v2.5-pro

# Anthropic (only needed when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Embedding Provider: "openai" or "local"
EMBEDDING_PROVIDER=local

# OpenAI Embedding (only needed when EMBEDDING_PROVIDER=openai)
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# Local Embedding (only needed when EMBEDDING_PROVIDER=local)
LOCAL_EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
LOCAL_EMBEDDING_DIMENSION=384

# Retrieval
DEFAULT_SEARCH_TOP_K=10
SUBGRAPH_MAX_DEPTH=2

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=hbrain
MINIO_SECURE=false

# MinerU (document parsing service)
MINERU_API_TOKEN=your_token_here
MINERU_API_BASE=https://mineru.net/api/v4
MINERU_MODEL=vlm

# Upload (legacy fallback)
UPLOAD_DIR=./data/uploads

# API
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=http://localhost:8000
DEBUG=false
